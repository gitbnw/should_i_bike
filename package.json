{
  "name": "should_i_bike",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsr generate && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "dev:all": "concurrently --raw \"npm run dev\" \"cd ../api_one && npm run start:dev\" --names \"frontend,backend\" --prefix-colors \"cyan,magenta\"",
    "restart:all": "concurrently --kill-others-on-fail --raw \"npm run dev\" \"cd ../api_one && npm run start:dev\" --names \"frontend,backend\" --prefix-colors \"cyan,magenta\"",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.143.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tanstack/router-cli": "1.143.6",
    "@tanstack/router-devtools": "^1.143.6",
    "@tanstack/router-vite-plugin": "^1.143.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.16"
  }
}
